# Web 환경 변수 템플릿. 복사해 .env.development / .env.production 으로 쓴다.
# NEXT_PUBLIC_* 는 빌드 시점에 박힌다. 실파일 커밋 금지.
# API 는 dev·운영 모두 /api 프리픽스로 서비스한다(API_GLOBAL_PREFIX=api).

# ── 개발 (.env.development) ──
NEXT_PUBLIC_API_BASE_URL=http://localhost:4010/api

# ── 운영 (.env.production) ──
# 운영 docker 빌드는 compose 의 web.build.args 가 /api(상대경로 same-origin)를 주입한다.
# NEXT_PUBLIC_API_BASE_URL=/api
