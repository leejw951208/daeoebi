generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  moduleFormat    = "cjs"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pg_trgm]
}

// WebAuthn passkey 자격증명 + PRF 로 래핑한 vault 키. 다중 기기 등록을 허용한다.
model WebauthnCredential {
  id           String    @id @default(cuid())
  credentialId Bytes     @unique // raw credential id
  publicKey    Bytes // COSE public key
  counter      BigInt    @default(0)
  transports   String[]
  deviceType   String?
  backedUp     Boolean   @default(false)
  prfSalt      Bytes // 이 자격증명의 PRF eval salt
  wrappedVkPrf Bytes // packed: iv||ct||tag
  nickname     String?
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  updatedAt    DateTime  @updatedAt
}

// 복구코드로 래핑한 vault 키(단일 행). 기기 분실 시 break-glass 용도이다.
model RecoveryWrap {
  id          String   @id @default("singleton")
  rcSalt      Bytes
  wrappedVkRc Bytes // packed: iv||ct||tag
  verifier    Bytes // SHA-256(복구코드 바이트). 복구 시점 상수시간 비교용. HKDF 키/평문 미보유.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 비밀번호를 묶는 최상위 단위. label 은 검색용 평문이고 icon 은 선택적이다.
model Site {
  id        String   @id @default(cuid())
  label     String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  secrets Secret[]

  @@index([label])
  @@index([label(ops: raw("gin_trgm_ops"))], type: Gin, map: "Site_label_trgm_idx")
}

// 자산(지출) 카테고리. 전역 평문(이름·색). 부모(Site) 없음.
model AssetCategory {
  id        String   @id @default(cuid())
  name      String
  color     String
  code      String?  @unique // 고정 카테고리 안정 식별자(고유). null = 사용자 생성. 저축·투자 대시보드 앵커로 사용한다.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  expenses  Expense[]
  recurring RecurringExpense[]

  @@index([name])
}

// 월 수입(자산 관리). 월별 다건 저장이며 금액은 암호문 블롭({amount})이다.
// 서버는 복호화하지 않는다(secret 과 동일 패스스루). month 는 "YYYY-MM" 평문으로 월 범위 조회용이다.
model Income {
  id         String   @id @default(cuid())
  month      String   // "YYYY-MM". 평문 — 월 범위 조회용.
  iv         Bytes
  ciphertext Bytes
  authTag    Bytes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([month])
}

// 저축 목표(단건 싱글톤). 금액은 클라이언트 E2E 암호문 블롭({amount}), name 은 평문 라벨.
// 서버는 복호화하지 않는다(income·secret 패스스루와 동일).
model SavingsGoal {
  id         String   @id @default(cuid())
  name       String
  iv         Bytes
  ciphertext Bytes
  authTag    Bytes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 투자 현재가(단건 싱글톤). 수익률은 평문 소수 문자열(정렬·표시용), 금액은 클라이언트 E2E 암호문 블롭({base}).
// 서버는 복호화하지 않는다(SavingsGoal 과 동일 패턴).
model InvestmentPosition {
  id         String   @id @default(cuid())
  returnRate String   @default("")
  iv         Bytes
  ciphertext Bytes
  authTag    Bytes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 저축 박스 입출금 내역(다건). type(in|out)·source(cash|savings)·date("YYYY-MM-DD") 평문(필터·정렬용),
// 금액·메모는 클라이언트 E2E 암호문 블롭({amount, memo})이다. 서버는 복호화하지 않는다(Income 과 동일 패턴).
model SavingsBoxTxn {
  id         String   @id @default(cuid())
  type       String // in|out
  source     String // cash|savings
  date       String // "YYYY-MM-DD". 평문 — 정렬·조회용.
  iv         Bytes
  ciphertext Bytes
  authTag    Bytes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([date])
}

// 적금 계좌(다건). name 평문(item 매칭·식별), color 평문. blob 은 {base, goal} 암호문.
model SavingsAccount {
  id         String   @id @default(cuid())
  name       String
  color      String
  iv         Bytes
  ciphertext Bytes
  authTag    Bytes
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// 고정 지출 템플릿. 매월 자동 생성의 원본이다. dayOfMonth·active·categoryId·method 는 스케줄/표시용 평문,
// 금액·항목만 암호문 블롭({item,amount})이다.
model RecurringExpense {
  id         String    @id @default(cuid())
  dayOfMonth Int // 1-31. 말일 초과 시 클라가 해당 월 말일로 클램프한다.
  startMonth String // "YYYY-MM". 평문. 이 달부터 인스턴스 생성(이전 달엔 미생성).
  termMonths Int? // null = 무기한. N = startMonth 부터 N개월간만 생성.
  active     Boolean   @default(true)
  categoryId String?
  category   AssetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  method     String? // 지출 방식(자유 입력, 평문). 고정 지출 탭 전용 — 인스턴스로 전파되지 않는다.
  iv         Bytes
  ciphertext Bytes
  authTag    Bytes
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  instances  Expense[]

  @@index([active, createdAt])
  @@index([categoryId])
}

// 지출 1건. date 는 월 범위 조회·달력용 평문, 본문은 암호문 블롭이다.
// recurringId/period 는 고정 지출 자동 생성의 멱등 키다(일반 지출은 둘 다 null).
model Expense {
  id          String            @id @default(cuid())
  date        DateTime          @db.Date
  recurringId String?
  recurring   RecurringExpense? @relation(fields: [recurringId], references: [id], onDelete: Cascade)
  period      String? // "YYYY-MM". 고정 인스턴스 멱등 키.
  removed     Boolean           @default(false) // 이번 달만 삭제(소프트 삭제). 목록·집계 제외, 슬롯 유지로 재생성 차단.
  categoryId  String?
  category    AssetCategory?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  iv          Bytes
  ciphertext  Bytes
  authTag     Bytes
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // 같은 템플릿·같은 달엔 1건만. null 끼리는 distinct 라 일반 지출엔 제약이 없다(멱등 머티리얼라이즈).
  @@unique([recurringId, period])
  @@index([removed, date])
  @@index([categoryId])
}

// 라벨 평문 + AEAD 암호화된 비밀번호 본문 1건.
// categoryId 가 null 이면 사이트 직속이다. 카테고리 삭제 시 사이트 직속으로 남는다.
model Secret {
  id         String    @id @default(cuid())
  siteId     String
  site       Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  label      String
  iv         Bytes
  ciphertext Bytes
  authTag    Bytes
  kdfVersion Int       @default(1)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([siteId, label])
  @@index([label(ops: raw("gin_trgm_ops"))], type: Gin, map: "Secret_label_trgm_idx")
}
