generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// 단일 사용자 마스터 패스워드의 KDF 파라미터와 verifyToken 을 보관한다.
// id 는 항상 "singleton" 고정값으로 단일 행을 강제한다.
model VaultMaster {
  id                String   @id @default("singleton")
  kdfVersion        Int      @default(1)
  kdfAlgorithm      String   @default("argon2id")
  kdfMemoryKiB      Int      @default(65536)
  kdfIterations     Int      @default(3)
  kdfParallelism    Int      @default(1)
  salt              Bytes
  verifyIv          Bytes
  verifyCiphertext  Bytes
  verifyAuthTag     Bytes
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// 6자리 PIN 접속 인증. id 는 "singleton" 고정으로 단일 행을 강제한다.
// pinHash 는 Argon2id 해시이며 PIN 은 암호화 키로 사용하지 않는다.
model PinCredential {
  id        String    @id @default("singleton")
  pinHash   String
  failCount Int       @default(0)
  lockUntil DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// 비밀번호를 묶는 최상위 단위. label 은 검색용 평문이고 icon 은 선택적이다.
model Site {
  id        String   @id @default(cuid())
  label     String
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories Category[]
  secrets    Secret[]

  @@index([label])
}

// 사이트 하위의 선택적 1계층 묶음. 자유 입력 라벨이다.
model Category {
  id        String   @id @default(cuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  label     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  secrets Secret[]

  @@index([siteId])
  @@index([label])
}

// 라벨 평문 + AEAD 암호화된 비밀번호 본문 1건.
// categoryId 가 null 이면 사이트 직속이다. 카테고리 삭제 시 사이트 직속으로 남는다.
model Secret {
  id         String    @id @default(cuid())
  siteId     String
  site       Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  label      String
  iv         Bytes
  ciphertext Bytes
  authTag    Bytes
  kdfVersion Int       @default(1)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([siteId])
  @@index([categoryId])
  @@index([label])
}
