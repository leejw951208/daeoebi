# API 환경 변수 템플릿. 복사해 .env.development(개발) / .env.production(운영) 으로 쓴다.
# 두 환경의 키 구성은 동일하고 값만 다르다(R2 백업 키만 운영 전용).
# 개발: ConfigModule 이 .env.development 로드. 운영: docker-compose 가 .env.production 을 env_file 주입.
# 실파일은 커밋 금지.

# ── 개발 (.env.development) ──
DATABASE_URL="postgresql://secrets:secrets@127.0.0.1:5431/daeoebi?schema=public"
HOST=::
PORT=4000
API_GLOBAL_PREFIX=api
TRUST_PROXY=0
COOKIE_SECURE=false
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=대외비
VAULT_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
CORS_ORIGIN=http://127.0.0.1:3000,http://localhost:3000
BOOTSTRAP_TOKEN=dev-bootstrap-token
POSTGRES_USER=secrets
POSTGRES_PASSWORD=secrets
POSTGRES_DB=daeoebi

# ── 운영 (.env.production) — 주석 풀고 값 채우기 ──
# DATABASE_URL="postgresql://secrets:CHANGE_ME@postgres:5432/daeoebi?schema=public"
# HOST=0.0.0.0
# PORT=4000
# API_GLOBAL_PREFIX=api
# TRUST_PROXY=1
# COOKIE_SECURE=true
# WEBAUTHN_RP_ID=vault.example.com
# WEBAUTHN_RP_NAME=대외비
# VAULT_ALLOWED_ORIGINS=https://vault.example.com
# CORS_ORIGIN=https://vault.example.com
# BOOTSTRAP_TOKEN=CHANGE_ME_LONG_RANDOM
# POSTGRES_USER=secrets
# POSTGRES_PASSWORD=CHANGE_ME
# POSTGRES_DB=daeoebi
# RCLONE_REMOTE=r2                  # (운영 전용) R2 백업
# R2_BUCKET=daeoebi-backups         # (운영 전용) R2 백업
