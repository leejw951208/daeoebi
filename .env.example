# 운영(docker compose) 환경 변수 템플릿. `cp .env.example .env` 후 값을 채운다.
# docker compose 가 같은 디렉터리의 .env 를 자동으로 읽어 ${VAR} 치환에 사용한다. .env 는 커밋 금지.

# ── 도메인 ─────────────────────────────────────────────
# Cloudflare 에서 구입한 운영 도메인(서브도메인 없이 apex). WebAuthn RP_ID·오리진의 기준이 된다.
DOMAIN=example.com
WEBAUTHN_RP_NAME=대외비

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_USER=secrets
# 강한 임의 비밀번호로 교체한다(예: openssl rand -base64 24).
POSTGRES_PASSWORD=change-me-strong-random
POSTGRES_DB=daeoebi

# ── R2 백업(scripts/backup-db.sh 에서 사용) ────────────
# rclone 으로 사전 설정한 R2 remote 이름과 버킷명.
RCLONE_REMOTE=r2
R2_BUCKET=daeoebi-backups
